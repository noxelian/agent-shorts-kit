{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agent-shorts-kit/episode.schema.json",
  "title": "Agent Shorts Kit episode",
  "type": "object",
  "required": ["topic", "title", "narration", "scenes", "description", "tags", "hashtags"],
  "properties": {
    "topic": {"type": "string", "minLength": 3},
    "title": {"type": "string", "minLength": 3, "maxLength": 100},
    "narration": {"type": "string", "minLength": 20},
    "scenes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 30,
      "items": {"type": "string", "minLength": 3}
    },
    "description": {"type": "string"},
    "tags": {"type": "array", "items": {"type": "string"}},
    "hashtags": {"type": "array", "items": {"type": "string", "pattern": "^#"}},
    "visual_bible": {"type": "string"},
    "callouts": {"type": "array"},
    "emphasis": {"type": "array"},
    "scene_effects": {"type": "array"}
  },
  "additionalProperties": true
}

